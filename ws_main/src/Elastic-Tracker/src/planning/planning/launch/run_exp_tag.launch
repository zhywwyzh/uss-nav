<launch>
  <group ns="drone0">
    <include file="$(find mapping)/launch/mapping_exp.launch"/>
    <node name="mapping_vis" pkg="mapping" type="mapping_vis_node">
      <remap from="~gridmap" to="gridmap"/>
      <remap from="~gridmap_inflate" to="gridmap_inflate"/>
    </node>
    <node pkg="odom_visualization" name="odom_visualization" type="odom_visualization" output="screen">
      <remap from="~odom" to="/ekf/ekf_odom" />
      <param name="robot_scale" value="1.0"/>
    </node>
    <node pkg="target_ekf" name="target_ekf_node" type="target_ekf_node" output="screen">
      <rosparam command="load" file="$(find target_ekf)/config/camera.yaml" />
      <param name="pitch_thr" value="37"/>
      <remap from="~yolo" to="/target/odom"/>
      <remap from="~odom" to="/ekf/ekf_odom"/>
      <remap from="~target_odom" to="/target_ekf_odom"/>
      <remap from="~yolo_odom" to="/target_original_odom"/>
      <remap from="~tag_position" to="/tag_detections_position"/>
      <remap from="~yolo_odom" to="/target_original_odom"/>
    </node>
    <include file="$(find planning)/launch/planning_exp.launch">
      <arg name="target_name_" value="/target_ekf_odom"/>
      <arg name="tracking_dist_" value="2.5"/>
      <arg name="vmax_" value="2.5"/>
      <arg name="amax_" value="2.5"/>
      <arg name="prediction_vmax_" value="4.0"/>
      <arg name="target_add_z_" value="0.0"/>
    </include>
  </group>
</launch>
