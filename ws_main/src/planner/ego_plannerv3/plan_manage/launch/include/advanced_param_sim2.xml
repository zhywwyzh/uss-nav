<launch>
    <arg name="odometry_topic"/>
    <arg name="camera_pose_topic"/>
    <arg name="depth_topic"/>
    <arg name="cloud_topic"/>
    <arg name="cx"/>
    <arg name="cy"/>
    <arg name="fx"/>
    <arg name="fy"/>
    <arg name="max_vel"/>
    <arg name="max_acc"/>
    <arg name="max_jer"/>
    <arg name="max_sna"/>

    <arg name="flight_type"/>
    <arg name="use_multitopology_trajs"/>
    <arg name="drone_id"/>

    <!-- main node -->
    <node pkg="exploration_manager" name="drone_$(arg drone_id)_ego_planner_node" type="exploration_node" output="screen">
        <remap from="~odom_world" to="/drone_$(arg drone_id)_$(arg odometry_topic)"/>
        <remap from="~mandatory_stop" to="/mandatory_stop_to_planner"/>
        <remap from="~planning/trajectory" to = "/drone_$(arg drone_id)_planning/trajectory"/>
        <remap from="~planning/data_display" to = "/drone_$(arg drone_id)_planning/data_display"/>
        <remap from="~planning/yaw_cmd" to = "/drone_$(arg drone_id)_planning/yaw_cmd"/>
        <remap from="~planning/broadcast_traj_send" to = "/broadcast_traj_from_planner"/>
        <remap from="~planning/broadcast_traj_recv" to = "/bridge/broadcast_traj_from_planner"/>
        <remap from="~planning/heartbeat" to = "/drone_$(arg drone_id)_traj_server/heartbeat"/>

        <!-- <remap from="/goal" to = "/goal_with_id"/> -->
        <!-- <remap from="/goal" to = "/move_base_simple/goal"/> -->
        <remap from ="/trigger" to="/move_base_simple/goal"/>
        <remap from="~grid_map/odom" to="/drone_$(arg drone_id)_$(arg odometry_topic)"/>

        <!-- <remap from="~grid_map/cloud" to="/drone_$(arg drone_id)_$(arg cloud_topic)"/> -->
        <remap from="~grid_map/cloud" to="$(arg cloud_topic)"/>
        <!-- <remap from="~grid_map/cloud" to="/livox/lidar_world"/> -->

        <remap from="~grid_map/pose"   to = "/drone_$(arg drone_id)_$(arg camera_pose_topic)"/>
        <remap from="~grid_map/depth" to = "/drone_$(arg drone_id)_$(arg depth_topic)"/>
        <remap from="/position_cmd" to="drone_$(arg drone_id)_planning/pos_cmd"/>
        <remap from="/tracking_target" to="/target_dist_calculator/detect_out"/>
        <!-- traj_server -->
        <param name="traj_server/time_forward" value="1.0" type="double"/>
        <param name="traj_server/max_yaw_vel" value="100.0" type="double"/>
        <param name="traj_server/max_yaw_acc" value="120.0" type="double"/>
        <param name="traj_server/max_yaw_vel_low" value="20.0" type="double"/>
        <param name="traj_server/max_yaw_acc_low" value="10.0" type="double"/>

        <!-- planning fsm -->
        <param name="fsm/flight_type" value="$(arg flight_type)" type="int"/>
        <param name="fsm/ground_height_measurement" value="true" type="bool"/>
        <!-- <param name="fsm/thresh_replan_time" value="1.0" type="double"/> -->
        <!-- <param name="fsm/planning_horizon" value="$(arg planning_horizon)" type="double"/> -->
        <!--always set to 1.5 times grater than sensing horizen-->
        <param name="fsm/scale" value="1.0" type="double"/>

        <param name="fsm/drone_id" value="$(arg drone_id)"/>
        <param name="fsm/arrive_dis_thr" value="0.2"/>
        <param name="fsm/odom_buffer_dis_threshold" value="0.05"/>
        <param name="fsm/follower_dis" value="0.8"/>
        <param name="fsm/emergency_time" value="1.0" type="double"/>
        <param name="fsm/realworld_experiment" value="false"/>
        <param name="fsm/fail_safe" value="true"/>
        <param name="fsm/battery_thr" value="14.0" type="double"/>
        <param name="fsm/enable_area_prediction" value="true" type="bool"/>
        <param name="fsm/auto_init_scene_graph" value="true" type="bool"/>
        <param name="fsm/auto_init_delay_sec" value="2.0" type="double"/>
        <!-- <param name="fsm/scene_graph_init_forward_dist" value="1.8" type="double"/> -->
        <param name="fsm/scene_graph_init_forward_dist" value="0.3" type="double"/>

        <!-- ego state trigger -->
        <param name="fsm/ego_state_trigger_pos_thresh" value="0.30" type="double"/>
        <param name="fsm/ego_state_trigger_vel_thresh" value="0.15" type="double"/>
        <param name="fsm/ego_state_trigger_acc_thresh" value="0.30" type="double"/>
        <param name="fsm/ego_state_trigger_yaw_rate_thresh" value="0.20" type="double"/>
        <param name="fsm/ego_state_trigger_hold_time" value="0.50" type="double"/>

        <!-- <param name="grid_map/resolution" value="0.1" /> -->
        <!-- local_map的size必须比depth_filter_maxdist大两个resoluiton -->
        <param name="grid_map/local_update_range_x" value="8.0" />
        <param name="grid_map/local_update_range_y" value="8.0" />
        <param name="grid_map/local_update_range_z" value="4.0" />
        <!-- <param name="grid_map/obstacles_inflation" value="0.5" /> -->
        <param name="grid_map/obstacles_inflation" value="0.3" />

        <param name="grid_map/local_map_margin" value="10"/>
        <param name="grid_map/enable_virtual_wall" value="false"/>
        <param name="grid_map/virtual_ceil" value="2.0"/>
        <param name="grid_map/virtual_ground" value="-0.1"/>
        <param name="grid_map/visual_inflat_map_height" value="2.0"/>

        <!-- camera parameter -->
        <param name="grid_map/cx" value="$(arg cx)"/>
        <param name="grid_map/cy" value="$(arg cy)"/>
        <param name="grid_map/fx" value="$(arg fx)"/>
        <param name="grid_map/fy" value="$(arg fy)"/>
        <!-- <param name="grid_map/k_depth_scaling_factor" value="1000.0"/> -->
        <param name="grid_map/k_depth_scaling_factor" value="1.0"/>
        <param name="grid_map/skip_pixel" value="2"/>
        <param name="grid_map/use_depth_filter" value="true"/>
        <param name="grid_map/depth_filter_maxdist"   value="4.5"/>
        <param name="grid_map/depth_filter_mindist"   value="0.1"/>
        <param name="grid_map/depth_filter_margin"    value="2"/>

        <!-- local fusion -->
        <!-- <param name="grid_map/p_hit" value="0.90"/>
        <param name="grid_map/p_miss" value="0.45"/> -->
        <param name="grid_map/p_hit" value="0.90"/>
        <param name="grid_map/p_miss" value="0.45"/>
        <param name="grid_map/p_min" value="0.12"/>
        <param name="grid_map/p_max" value="0.90"/>
        <param name="grid_map/p_occ" value="0.80"/>
        <param name="grid_map/fading_time" value="-1.0"/>
        <param name="grid_map/min_ray_length" value="0.1"/>
        <!-- <param name="grid_map/max_ray_length" value="10.0"/> -->
        <param name="grid_map/max_ray_length" value="4.0"/>
        <param name="grid_map/show_occ_time" value="false"/>
        <param name="grid_map/pose_type" value="1"/>
        <param name="grid_map/frame_id" value="world"/>
        <param name="grid_map/hit_accum_max" value="40" /> 
        <param name="grid_map/hit_accum_threshold" value="10" />

        <!-- Perception utils -->
        <param name="perception_utils/top_angle" value="0.6" type="double"/>;
        <param name="perception_utils/left_angle" value="0.76" type="double"/>;
        <param name="perception_utils/right_angle" value="0.76" type="double"/>;
        <param name="perception_utils/max_dist" value="6.0" type="double"/>;
        <param name="perception_utils/vis_dist" value="1.0" type="double"/>;

        <!-- posegraph -->
        <param name="posegraph/connected_min_seqential_dis" value="4.0" type="double"/>
        <param name="posegraph/connected_max_euler_dis" value="2.0" type="double"/>
        <param name="posegraph/keypose_min_gap" value="1.0" type="double"/>

        <!-- frontier -->
        <param name="frontier/floor" value="1.0" type="double"/>
        <param name="frontier/ceil" value="1.6" type="double"/>
        <param name="frontier/cluster_min" value="100" type="int"/>
        <param name="frontier/cluster_size_xy" value="2.0" type="double"/>
        <param name="frontier/cluster_size_z" value="10.0" type="double"/>
        <param name="frontier/down_sample" value="3" type="int"/>;
        <param name="frontier/min_candidate_dist" value="0.51" type="double"/>
        <param name="frontier/min_candidate_clearance_xy" value="0.21" type="double"/>
        <param name="frontier/min_candidate_clearance_z" value="0.21" type="double"/>
        <param name="frontier/min_candidate_clearance_unknown_xy" value="0.21" type="double"/>
        <param name="frontier/min_candidate_clearance_unknown_z" value="0.21" type="double"/>
        <param name="frontier/candidate_dphi" value="$(eval 30 * 3.1415926 / 180.0)" type="double"/>
        <param name="frontier/candidate_phinum" value="6" type="int"/>
        <param name="frontier/candidate_rnum" value="4" type="int"/>
        <param name="frontier/candidate_rmin" value="0.8" type="double"/>
        <param name="frontier/candidate_rmax" value="2.2" type="double"/>
        <param name="frontier/candidate_znum" value="3" type="int"/>
        <param name="frontier/candidate_zmin" value="-0.2" type="double"/>
        <param name="frontier/candidate_zmax" value="0.2" type="double"/>
        <param name="frontier/min_visib_num" value="4" type="int"/>;
        <param name="frontier/min_view_finish_fraction" value="0.5" type="double"/>;
        <param name="frontier/ftr_blacklist_radius" value="1.0" type="double"/>;
        <param name="frontier/print_info" value="false" type="bool"/>;
        
        <!-- Hgrid -->
        <param name="global_map/box_min_x" value="-20" type="double"/>
        <param name="global_map/box_min_y" value="-20" type="double"/>
        <param name="global_map/box_min_z" value="0" type="double"/> 
        <param name="global_map/box_max_x" value="36" type="double"/>
        <param name="global_map/box_max_y" value="8" type="double"/>
        <param name="global_map/box_max_z" value="2.0" type="double"/>
        <!-- Hgrid 会判断当格子里的unknown_cell数量小于min_unknown且格子里无ftr,则判断covered -->
        <param name="partitioning/min_unknown" value="800" type="int"/>;
        <param name="partitioning/min_frontier" value="100" type="int"/>;
        <!-- 格子里free数量大于min_free才会divided -->
        <param name="partitioning/min_free" value="5000" type="int"/>;
        <param name="partitioning/consistent_cost" value="-5" type="double"/>;
        <param name="partitioning/consistent_cost2" value="8" type="double"/>;
        <param name="partitioning/w_unknown" value="0.0" type="double"/>;
        <param name="partitioning/grid_size" value="1.8" type="double"/>;
        <param name="partitioning/use_swarm_tf" value="false" type="bool"/>;
        <param name="partitioning/hgrid_vis_range" value="10" type="int"/>; <!-- -1: display all hgrids -->
        <param name="partitioning/multilayer_hgrid" value="false" type="bool"/>; <!-- 0: monolayer hgrid 1: multilayer hgrid -->
        <param name="partitioning/print_info" value="false" type="bool"/>;

        <!-- exploration -->
        <param name="exploration/radius_close_goal" value="1.5" type="double"/>
        <param name="exploration/radius_far_goal" value="7.5" type="double"/>
        <param name="exploration/refine_local" value="false" type="bool"/>
        <param name="exploration/refined_num" value="4" type="int"/>
        <param name="exploration/refined_radius" value="5.0" type="double"/>
        <param name="exploration/max_decay" value="0.8" type="double"/>
        <param name="exploration/top_view_num" value="15" type="int"/>
        <param name="exploration/vm" value="1.5" type="double"/>
        <param name="exploration/am" value="2.0" type="double"/>
        <param name="exploration/yd" value="$(eval 30 * 3.1415926 / 180.0)" type="double"/>
        <param name="exploration/ydd" value="$(eval 45 * 3.1415926 / 180.0)" type="double"/>
        <param name="exploration/w_dir" value="2.0" type="double"/>
        <param name="exploration/tsp_dir" value="$(find lkh_tsp_solver)/resource" type="string"/>
        <param name="exploration/relax_time" value="1.0" type="double"/>

        <!-- tracking -->
        <param name="tracking/track_dist" value="2.5" type="double"/>
        <param name="tracking/dist_far" value="20.0" type="double"/>
        <param name="tracking/replan_dist" value="0.25" type="double"/>
        <param name="tracking/turn_yaw_dist" value="100.0" type="double"/>
        <param name="tracking/yaw_threshold" value="0.15" type="double"/>
        <param name="tracking/detect_error" value="2.0" type="double"/>

        <!-- skeleton -->
        <param name="skeleton/local_x_max" value="4"/>
        <param name="skeleton/local_x_min" value="-2"/>
        <param name="skeleton/local_y_max" value="4"/>
        <param name="skeleton/local_y_min" value="-4"/>
        <param name="skeleton/local_z_max" value="1.0"/>
        <param name="skeleton/local_z_min" value="-1.0"/>

        <param name="skeleton/expand_time_limit" value="60"/>   <!-- MS -->

        <param name="skeleton/frontier_creation_threshold" value="0.3"/>
        <param name="skeleton/frontier_jump_threshold" value="3.0"/>
        <param name="skeleton/frontier_split_threshold" value="2.0"/>
        <param name="skeleton/min_loop_creation_threshold" value="1"/>
        <param name="skeleton/min_flowback_creation_radius_threshold" value="0.5"/>
        <param name="skeleton/min_node_radius" value="0.6"/>
        <param name="skeleton/min_node_dense_radius" value="1.0"/>
        <param name="skeleton/search_margin" value="0.2"/>
        <param name="skeleton/max_ray_length" value="1.4"/>
        <param name="skeleton/max_expansion_ray_length" value="2.0"/>
        <param name="skeleton/max_height_diff" value="1.5"/>

        <param name="skeleton/sampling_density" value="50"/>    <!-- Fibonicci-sphere sampling -->
        <param name="skeleton/sampling_level" value="4"/>       <!-- proposed sampling method -->

        <param name="skeleton/max_facets_grouped" value="4"/>
        <param name="skeleton/resolution" value="0.1"/>
        <param name="skeleton/truncated_z_high" value="2.5"/>
        <param name="skeleton/truncated_z_low" value="0"/>

        <param name="skeleton/debug_mode" value="false"/>
        <param name="skeleton/bad_loop" value="true"/>

        <param name="skeleton/visualize_final_result_only" value="true"/>
        <param name="skeleton/visualize_all" value="true"/>
        <param name="skeleton/visualize_outwards_normal" value="true"/>
        <param name="skeleton/visualize_nbhd_frontiers" value="false"/>
        <param name="skeleton/visualize_black_polygon" value="true"/>

        <param name="obj/camera_fx" type="double" value="442.0250167097101"/>
        <param name="obj/camera_fy" type="double" value="442.0250167097101"/>
        <param name="obj/camera_cx" type="double" value="320.0"/>
        <param name="obj/camera_cy" type="double" value="240.0"/>
        <param name="obj/lidar_cam_tx" type="double" value="0.0"/>
        <param name="obj/lidar_cam_ty" type="double" value="0.0"/>
        <param name="obj/lidar_cam_tz" type="double" value="0.0"/>
        <param name="obj/lidar_cam_pitch" type="double" value="0.0"/>
        <param name="obj/lidar_cam_roll" type="double" value="0.0"/>
        <param name="obj/lidar_cam_yaw" type="double" value="0.0"/>

        <param name="obj/use_realsense" type="bool" value="false"/>
        <param name="obj/use_camera_intrinsics" type="bool" value="false"/>
        <param name="obj/fov_vertical" type="double" value="57.0"/>
        <param name="obj/fov_horizontal" type="double" value="71.0"/>
        <param name="obj/cam_resolution_h" type="int" value="480"/>
        <param name="obj/cam_resolution_w" type="int" value="640"/>
        <param name="obj/max_depth" type="double" value="5.0"/>
        <param name="obj/min_depth" type="double" value="0.2"/>
        <param name="obj/max_ray_length" type="double" value="4.0"/>

        <param name="obj/voxel_size" type="double" value="0.05"/>
        <param name="obj/mean_k" type="int" value="60"/>
        <param name="obj/std_dev_thresh" type="double" value="0.01"/>
        <param name="obj/obj_cloud_num_thresh" type="int" value="20"/>
        <param name="obj/detection_counter_thresh" type="int" value="5"/>

        <param name="obj/filter_run_duration" type="double" value="3.0"/>
        <param name="obj/obj_main_thread_run_hz" type="int" value="5"/>

        <param name="obj/seg_result_topic" type="string" value="/yoloe/encodemask"/>
        <param name="obj/depth_cloud_disp_all" type="bool" value="false"/>
        <param name="obj/max_threads" type="int" value="4"/>

        <!-- Fsm -->
        <!-- if time to the end of the traj < thresh_replan1 -->
        <param name="fsm/thresh_replan1" value="0.5" type="double"/>
        <!-- if aim Frontier Covered & time > thresh_replan2 -->
        <param name="fsm/thresh_replan2" value="1.5" type="double"/>
        <!-- if time > thresh_replan3 -->
        <param name="fsm/thresh_replan3" value="15.0" type="double"/>

        <param name="fsm/replan_time" value="0.200" type="double"/>
        <param name="fsm/target_cmd" value="Find shelf full of stroage boxes" type="string"/>

        <!-- planner manager -->
        <param name="manager/max_vel" value="$(arg max_vel)" type="double"/>
        <param name="manager/max_acc" value="$(arg max_acc)" type="double"/>
        <!-- <param name="manager/polyTraj_piece_length" value="1.25" type="double"/> -->
        <!-- <param name="manager/planning_horizon" value="$(arg planning_horizon)" type="double"/> -->
        <param name="manager/use_multitopology_trajs" value="$(arg use_multitopology_trajs)" type="bool"/>
        <param name="manager/drone_id" value="$(arg drone_id)"/>

        <!-- trajectory optimization -->
        <!-- <param name="optimization/constraint_points_perPiece" value="5" type="int"/> -->
        <param name="optimization/weight_obstacle" value="10000.0" type="double"/>
        <param name="optimization/weight_obstacle_soft" value="0.0" type="double"/>
        <param name="optimization/weight_trust_region" value="10.0" type="double"/>
        <param name="optimization/weight_curve_fitting" value="1000.0" type="double"/>
        <param name="optimization/weight_plane" value="10.0" type="double"/>
        <param name="optimization/weight_swarm" value="10000.0" type="double"/>
        <param name="optimization/weight_feasibility" value="250.0" type="double"/>
        <param name="optimization/weight_sqrvariance" value="0.0" type="double"/>
        <param name="optimization/weight_time" value="10.0" type="double"/>
        <param name="optimization/obstacle_clearance" value="0.1" type="double"/>
        <param name="optimization/obstacle_clearance_soft" value="1.5" type="double"/>
        <param name="optimization/swarm_clearance" value="0.45" type="double"/> <!-- heterogeneous support: my required clearance -->
        <!-- <param name="optimization/max_vel" value="$(arg max_vel)" type="double"/>
        <param name="optimization/max_acc" value="$(arg max_acc)" type="double"/> -->
        <param name="optimization/max_jer" value="$(arg max_jer)" type="double"/>
        <param name="optimization/max_sna" value="$(arg max_sna)" type="double"/>
    </node>
</launch>
