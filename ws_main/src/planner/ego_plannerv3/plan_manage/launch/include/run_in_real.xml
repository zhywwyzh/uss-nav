<launch>
    <!-- size of map, change the size inflate x, y, z according to your application -->
    <arg name="drone_id" default="0"/>
    <arg name="map_size_x"/>
    <arg name="map_size_y"/>
    <arg name="map_size_z"/>
    <arg name="init_x"/>
    <arg name="init_y"/>
    <arg name="init_z"/>
    <arg name="flight_type" default="2"/>
    <arg name="point_num" default="1"/>
    <arg name="target0_x" default="0.0"/>
    <arg name="target0_y" default="0.0"/>
    <arg name="target0_z" default="0.0"/>
    <arg name="target1_x" default="0.0"/>
    <arg name="target1_y" default="0.0"/>
    <arg name="target1_z" default="0.0"/>
    <arg name="target2_x" default="0.0"/>
    <arg name="target2_y" default="0.0"/>
    <arg name="target2_z" default="0.0"/>
    <arg name="target3_x" default="0.0"/>
    <arg name="target3_y" default="0.0"/>
    <arg name="target3_z" default="0.0"/>
    <arg name="target4_x" default="0.0"/>
    <arg name="target4_y" default="0.0"/>
    <arg name="target4_z" default="0.0"/>
    <!-- topic of your odometry such as VIO or LIO -->
    <arg name="odom_topic" default="/ekf_quat/ekf_odom"/>
    <arg name="tracking_backend" default="ego"/>
    <arg name="tracking_target_odom_topic" default="/target_ekf_odom"/>
    <arg name="planner_cmd_mux_ego_topic" default="/planner_mux/ego_position_cmd"/>
    <arg name="planner_cmd_mux_elastic_topic" default="/planner_mux/elastic_position_cmd"/>
    <arg name="planner_cmd_mux_mode_topic" default="/planner_mux/mode"/>
    <arg name="planner_cmd_mux_output_topic" default="/setpoint_cmd"/>
    <arg name="elastic_tracker_trigger_topic" default="/triger"/>
    <arg name="elastic_tracker_finish_topic" default="/elastic_tracker/tracking_finish"/>
    <arg name="elastic_tracker_stop_topic" default="/elastic_tracker/stop"/>

	<!-- swarm topic transmitter bridge-->
<!--	<include file="$(find swarm_bridge)/launch/bridge_tcp_drone_fy_sim.launch">-->
<!--		<arg name="drone_id" value="$(arg drone_id)"/>-->
<!--        <arg name="broadcast_odom_from_planner" value="$(arg odom_topic)"/>-->
<!--	</include>-->

    <!-- main algorithm params -->
    <include file="$(find ego_planner)/launch/include/advanced_param_real.xml">
        <arg name="drone_id" value="$(arg drone_id)"/>
        <arg name="odometry_topic" value="$(arg odom_topic)"/>
        <!-- camera pose: transform of camera frame in the world frame -->
        <!-- depth topic: depth image, 640x480 by default -->
        <!-- don't set cloud_topic if you already set these ones! -->
        <arg name="camera_pose_topic" value="pcl_render_node/camera_pose"/>
        <arg name="depth_topic" value="pcl_render_node/depth"/>
        <!-- topic of point cloud measurement, such as from LIDAR  -->
        <!-- don't set camera pose and depth, if you already set this one! -->
        <!-- <arg name="cloud_topic" value="/cloud_fov_limited"/> -->
        <arg name="cloud_topic" value="laserMapping/cloud_registered"/>
        <!-- intrinsic params of the depth camera -->
        <arg name="cx" value="321.04638671875"/>
        <arg name="cy" value="243.44969177246094"/>
        <arg name="fx" value="387.229248046875"/>
        <arg name="fy" value="387.229248046875"/>
        <!-- maximum velocity, acceleration and jerk the drone will reach -->
        <!-- <arg name="max_vel" value="10.0" />
        <arg name="max_acc" value="8.0" />
        <arg name="max_jer" value="10.0" />
        <arg name="max_sna" value="20.0" /> -->
        <arg name="max_vel" value="1.0" />
        <arg name="max_acc" value="1.0" />
        <arg name="max_jer" value="2.0" />
        <arg name="max_sna" value="5.0" />
        <!--always set to 1.5 times grater than sensing horizen !!!-->
        <!-- <arg name="planning_horizon" value="12.0" /> -->
        <arg name="use_multitopology_trajs" value="false" />
        <arg name="tracking_backend" value="$(arg tracking_backend)" />
        <arg name="tracking_target_odom_topic" value="$(arg tracking_target_odom_topic)" />
        <arg name="planner_cmd_mux_ego_topic" value="$(arg planner_cmd_mux_ego_topic)" />
        <arg name="planner_cmd_mux_mode_topic" value="$(arg planner_cmd_mux_mode_topic)" />
        <arg name="elastic_tracker_trigger_topic" value="$(arg elastic_tracker_trigger_topic)" />
        <arg name="elastic_tracker_finish_topic" value="$(arg elastic_tracker_finish_topic)" />
        <arg name="elastic_tracker_stop_topic" value="$(arg elastic_tracker_stop_topic)" />
        <!-- 1: use 2D Nav Goal to select goal  -->
        <!-- 2: use global waypoints below  -->
        <arg name="flight_type" value="$(arg flight_type)" />
    </include>

    <node pkg="exploration_manager" type="planner_cmd_mux" name="drone_$(arg drone_id)_planner_cmd_mux" output="screen">
        <remap from="~ego_position_cmd" to="$(arg planner_cmd_mux_ego_topic)"/>
        <remap from="~elastic_position_cmd" to="$(arg planner_cmd_mux_elastic_topic)"/>
        <remap from="~mode" to="$(arg planner_cmd_mux_mode_topic)"/>
        <remap from="~position_cmd" to="$(arg planner_cmd_mux_output_topic)"/>
        <param name="default_mode" value="ego" type="string"/>
        <param name="ego_mode" value="ego" type="string"/>
        <param name="elastic_mode" value="elastic" type="string"/>
        <param name="input_timeout" value="0.5" type="double"/>
    </node>
    
</launch>
    
