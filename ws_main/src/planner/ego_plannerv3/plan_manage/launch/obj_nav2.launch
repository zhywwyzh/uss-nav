<launch>
    <arg name="map_size_x" value="200.0"/>
    <arg name="map_size_y" value="200.0"/>
    <arg name="map_size_z" value=" 3.0"/>
    <arg name="init_x" value="0.0"/>
    <arg name="init_y" value="0.0"/>
    <arg name="init_z" value="1.0"/>

    <arg name="odom_topic" default="visual_slam/odom" />
    <arg name="cloud_topic" default="mid360/points" />

    <include file="$(find ego_planner)/launch/include/run_in_sim2.xml">
        <arg name="drone_id" value="0"/>
        <arg name="init_x" value="$(arg init_x)" />
        <arg name="init_y" value="$(arg init_y)" />
        <arg name="init_z" value="$(arg init_z)" />
        <arg name="map_size_x" value="$(arg map_size_x)"/>
        <arg name="map_size_y" value="$(arg map_size_y)"/>
        <arg name="map_size_z" value="$(arg map_size_z)"/>
        <arg name="odom_topic" value="$(arg odom_topic)"/>
        <arg name="cloud_topic" value="$(arg cloud_topic)"/>

        <!-- MANUAL_TARGET  = 1, // Set aim in rviz
             EXPLORE_TARGET = 2, // Get aim from Exploration 
             PRESET_TARGET  = 3, // Get preset aim from launch file -->
        <arg name="flight_type" value="2"/>
    </include>
</launch>
