    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Planning1
        - /Planning1/bspline_traj1/Namespaces1
        - /active_perception1
        - /active_perception1/frontier1/Namespaces1
